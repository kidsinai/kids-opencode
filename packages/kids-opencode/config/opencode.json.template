{
  "$schema": "https://opencode.ai/config-schema.json",
  "_comment": "kids-opencode opencode preset. install.sh copies this to ~/.config/kids-opencode/opencode.json on first install. Edit there, not here.",

  "plugin": [
    "@kidsinai/kids-opencode-plugin"
  ],

  "provider": {
    "_comment": "All LLM calls go through DeepRouter. The DEEPROUTER_API_KEY env var holds the per-family tenant key issued at parent-onboarding time. Do NOT put raw provider keys here.",
    "deeprouter": {
      "type": "openai-compatible",
      "baseURL": "https://api.deeprouter.ai/v1",
      "apiKey": "{env:DEEPROUTER_API_KEY}"
    }
  },

  "model": "deeprouter/claude-3-5-sonnet",

  "agent": {
    "_comment": "Tool whitelist enforced by the kids plugin. Listing them here is documentation; the plugin is the source of truth for what's allowed.",
    "tools": ["read", "write", "edit", "glob", "grep", "webfetch"]
  },

  "permission": {
    "_comment": "Tools require explicit approval before execution. Kids should always see what's about to happen.",
    "default": "ask",
    "tools": {
      "read": "ask",
      "write": "ask",
      "edit": "ask",
      "glob": "ask",
      "grep": "ask",
      "webfetch": "ask"
    }
  }
}
