    "test": "sh -n bin/kids-opencode && sh -n scripts/postinstall.sh"
  },
  "files": [
    "bin",
    "scripts",
    "config",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "@kidsinai/kids-client": "^0.0.3",
