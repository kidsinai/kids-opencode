{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "cream100":      "#FAF6F0",
    "cream200":      "#F4ECDC",
    "tan300":        "#E8DCC8",
    "tan400":        "#D4C4A8",
    "tan500":        "#BFAB87",
    "brown700":      "#8B6F4E",
    "brown800":      "#5C4530",
    "brown900":      "#3D2914",

    "sunrise500":    "#FF8C42",
    "sunrise600":    "#E87530",
    "coral500":      "#E85B5B",
    "coral600":      "#CC4848",
    "lavender500":   "#9B7EBD",
    "mint500":       "#4FB069",
    "mint600":       "#3D8E54",
    "sky500":        "#4A9EE0",
    "sky600":        "#3380C2",
    "sunflower500":  "#F5A623",
    "sunflower600":  "#D88E15",

    "darkBg":        "#1A1424",
    "darkPanel":     "#251B30",
    "darkElement":   "#33263F",
    "darkText":      "#F2E4D3",
    "darkTextMuted": "#BFA98E",
    "darkBorder":    "#3F2F4F",
    "darkBorderActive": "#7D5C9C",

    "darkAddedBg":   "#1F2A1F",
    "darkRemovedBg": "#2A1F1F",
    "darkContextBg": "#23192E",
    "darkAddedLineNumberBg": "#2A3B2A",
    "darkRemovedLineNumberBg": "#3B2A2A",
    "lightAddedBg":  "#E6F2DA",
    "lightRemovedBg":"#F4DADA",
    "lightContextBg":"#F4ECDC",
    "lightAddedLineNumberBg":   "#D8E8C8",
    "lightRemovedLineNumberBg": "#EFCCCC",
    "lightLineNumber":          "#A8957A",
    "lineNumberDark":           "#8B7A66"
  },
  "theme": {
    "primary":               { "light": "sunrise500", "dark": "sunrise500" },
    "secondary":             { "light": "coral500",   "dark": "lavender500" },
    "accent":                { "light": "lavender500","dark": "lavender500" },
    "error":                 { "light": "coral600",   "dark": "coral500" },
    "warning":               { "light": "sunflower600","dark": "sunflower500" },
    "success":               { "light": "mint600",    "dark": "mint500" },
    "info":                  { "light": "sky600",     "dark": "sky500" },

    "text":                  { "light": "brown900",   "dark": "darkText" },
    "textMuted":             { "light": "brown700",   "dark": "darkTextMuted" },

    "background":            { "light": "cream100",   "dark": "darkBg" },
    "backgroundPanel":       { "light": "cream200",   "dark": "darkPanel" },
    "backgroundElement":     { "light": "tan300",     "dark": "darkElement" },

    "border":                { "light": "tan400",     "dark": "darkBorder" },
    "borderActive":          { "light": "sunrise500", "dark": "darkBorderActive" },
    "borderSubtle":          { "light": "tan300",     "dark": "darkBorder" },

    "diffAdded":             { "light": "mint600",    "dark": "mint500" },
    "diffRemoved":           { "light": "coral600",   "dark": "coral500" },
    "diffContext":           { "light": "brown700",   "dark": "darkTextMuted" },
    "diffHunkHeader":        { "light": "sunrise600", "dark": "sunrise500" },
    "diffHighlightAdded":    { "light": "mint600",    "dark": "mint500" },
    "diffHighlightRemoved":  { "light": "coral600",   "dark": "coral500" },
    "diffAddedBg":           { "light": "lightAddedBg",   "dark": "darkAddedBg" },
    "diffRemovedBg":         { "light": "lightRemovedBg", "dark": "darkRemovedBg" },
    "diffContextBg":         { "light": "lightContextBg", "dark": "darkContextBg" },
    "diffLineNumber":        { "light": "lightLineNumber","dark": "lineNumberDark" },
    "diffAddedLineNumberBg": { "light": "lightAddedLineNumberBg",   "dark": "darkAddedLineNumberBg" },
    "diffRemovedLineNumberBg":{ "light": "lightRemovedLineNumberBg","dark": "darkRemovedLineNumberBg" },

    "markdownText":          { "light": "brown900",   "dark": "darkText" },
    "markdownHeading":       { "light": "sunrise600", "dark": "sunrise500" },
    "markdownLink":          { "light": "sky600",     "dark": "sky500" },
    "markdownLinkText":      { "light": "sky600",     "dark": "sky500" },
    "markdownCode":          { "light": "brown800",   "dark": "sunflower500" },
    "markdownBlockQuote":    { "light": "brown700",   "dark": "darkTextMuted" },
    "markdownEmph":          { "light": "brown800",   "dark": "darkText" },
    "markdownStrong":        { "light": "brown900",   "dark": "darkText" },
    "markdownHorizontalRule":{ "light": "tan400",     "dark": "darkBorder" },
    "markdownListItem":      { "light": "brown900",   "dark": "darkText" },
    "markdownListEnumeration":{"light": "sunrise600", "dark": "sunrise500" },
    "markdownImage":         { "light": "sky600",     "dark": "sky500" },
    "markdownImageText":     { "light": "brown700",   "dark": "darkTextMuted" },
    "markdownCodeBlock":     { "light": "brown800",   "dark": "sunflower500" },

    "syntaxComment":         { "light": "tan500",     "dark": "darkTextMuted" },
    "syntaxKeyword":         { "light": "coral600",   "dark": "coral500" },
    "syntaxFunction":        { "light": "sunrise600", "dark": "sunrise500" },
    "syntaxVariable":        { "light": "brown900",   "dark": "darkText" },
    "syntaxString":          { "light": "mint600",    "dark": "mint500" },
    "syntaxNumber":          { "light": "sunflower600","dark": "sunflower500" },
    "syntaxType":            { "light": "sky600",     "dark": "sky500" },
    "syntaxOperator":        { "light": "brown700",   "dark": "darkTextMuted" },
    "syntaxPunctuation":     { "light": "brown700",   "dark": "darkTextMuted" }
  }
}
