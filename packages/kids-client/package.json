    "@kidsinai/kids-opencode-plugin": "^0.0.1"
  },
  "devDependencies": {
    "@opencode-ai/sdk": "^1.14.51",
    "@types/react": "^18.3.12",
    "ink-testing-library": "^4.0.0",
    "typescript": "^5.7.0"
  }
