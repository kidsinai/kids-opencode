  "license": "MIT",
  "homepage": "https://github.com/kidsinai/kids-opencode",
  "repository": {
    "type": "git",
    "url": "https://github.com/kidsinai/kids-opencode.git",
    "directory": "packages/kids-client"
  },
  "keywords": ["opencode", "kids", "tui", "ink", "education", "k-12", "agentic"],
  "bin": {
